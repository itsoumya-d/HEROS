// The --describe output: a complete machine-readable schema of all Forge commands,
// flags, input formats, and return shapes. This is the primary discovery mechanism
// for agents that have never encountered Forge before.
//
// Principle: A cold LLM should be able to use Forge end-to-end using only
// the output of this function.

pub fun writeDescribe(world: World) -> Void raises {
    check world.out.write("{\n")
    check world.out.write("  \"name\": \"forge\",\n")
    check world.out.write("  \"version\": \"0.1.4\",\n")
    check world.out.write("  \"schema_version\": 1,\n")
    check world.out.write("  \"description\": \"Agent-safe database schema migration engine. Analyzes DDL schema changes and returns structured JSON risk reports. Built for agent-first usage: no interactive prompts, no ANSI codes, stable error codes.\",\n")
    check world.out.write("  \"invocation\": \"forge <command> [flags] --json\",\n")
    check world.out.write("  \"commands\": [\n")

    // analyze command
    check world.out.write("    {\n")
    check world.out.write("      \"name\": \"analyze\",\n")
    check world.out.write("      \"description\": \"Analyze the risk of migrating from one schema to another. Returns a structured risk report with per-operation risk scores and agent guidance. Call this before executing any schema change. Does NOT modify any database - read-only analysis.\",\n")
    check world.out.write("      \"when_to_use\": \"Before running any database migration. Input is two .forge schema files describing the current and desired state.\",\n")
    check world.out.write("      \"when_not_to_use\": \"Do not use to execute migrations - use execute command for that (not yet implemented in v0.1.x).\",\n")
    check world.out.write("      \"flags\": [\n")
    check world.out.write("        {\n")
    check world.out.write("          \"name\": \"--from\",\n")
    check world.out.write("          \"type\": \"string\",\n")
    check world.out.write("          \"required\": true,\n")
    check world.out.write("          \"description\": \"Path to the CURRENT (before) schema file in Forge Schema Format (.forge). Example: --from current.forge\"\n")
    check world.out.write("        },\n")
    check world.out.write("        {\n")
    check world.out.write("          \"name\": \"--to\",\n")
    check world.out.write("          \"type\": \"string\",\n")
    check world.out.write("          \"required\": true,\n")
    check world.out.write("          \"description\": \"Path to the DESIRED (after) schema file in Forge Schema Format (.forge). Example: --to desired.forge\"\n")
    check world.out.write("        },\n")
    check world.out.write("        {\n")
    check world.out.write("          \"name\": \"--dialect\",\n")
    check world.out.write("          \"type\": \"string\",\n")
    check world.out.write("          \"required\": false,\n")
    check world.out.write("          \"default\": \"postgresql\",\n")
    check world.out.write("          \"enum\": [\"postgresql\"],\n")
    check world.out.write("          \"description\": \"Database dialect for risk analysis. Currently only postgresql is supported.\"\n")
    check world.out.write("        },\n")
    check world.out.write("        {\n")
    check world.out.write("          \"name\": \"--json\",\n")
    check world.out.write("          \"type\": \"boolean\",\n")
    check world.out.write("          \"required\": false,\n")
    check world.out.write("          \"default\": true,\n")
    check world.out.write("          \"description\": \"Emit output as JSON. Always set this flag when calling from an agent.\"\n")
    check world.out.write("        }\n")
    check world.out.write("      ],\n")
    check world.out.write("      \"output_schema\": {\n")
    check world.out.write("        \"schema_version\": \"integer - always 1\",\n")
    check world.out.write("        \"risk_tier\": \"string - SAFE, NOTABLE, MEDIUM, HIGH, or CRITICAL (worst operation determines tier)\",\n")
    check world.out.write("        \"risk_score\": \"float - 0.0 (SAFE) to 1.0 (CRITICAL)\",\n")
    check world.out.write("        \"retryable\": \"boolean - whether the entire migration can be retried safely\",\n")
    check world.out.write("        \"has_data_loss\": \"boolean - true if any operation irreversibly destroys data\",\n")
    check world.out.write("        \"operations\": \"array - each element is a MigOp object (see migop_schema)\"\n")
    check world.out.write("      },\n")
    check world.out.write("      \"migop_schema\": {\n")
    check world.out.write("        \"type\": \"string - one of: add_column, drop_column, add_table, drop_table, set_not_null, drop_not_null, set_default, drop_default, change_type\",\n")
    check world.out.write("        \"table\": \"string - name of affected table\",\n")
    check world.out.write("        \"column\": \"string - name of affected column (absent for table-level operations)\",\n")
    check world.out.write("        \"risk\": \"string - one of: safe, notable, medium, high, critical\",\n")
    check world.out.write("        \"data_loss\": \"boolean - true if this operation permanently destroys data\",\n")
    check world.out.write("        \"estimated_lock_ms\": \"integer - estimated table lock duration in milliseconds (0 = no lock)\",\n")
    check world.out.write("        \"retryable\": \"boolean - whether this specific operation can be safely retried on failure\",\n")
    check world.out.write("        \"agent_guidance\": \"string - advice for this specific operation\"\n")
    check world.out.write("      }\n")
    check world.out.write("    }\n")
    check world.out.write("  ],\n")

    // Input format documentation
    check world.out.write("  \"forge_schema_format\": {\n")
    check world.out.write("    \"description\": \"Forge Schema Format (.forge) is a simple line-oriented schema description language.\",\n")
    check world.out.write("    \"syntax\": \"TABLE <name>\\nCOLUMN <name> <type> [NOT_NULL] [NULLABLE] [PRIMARY_KEY] [DEFAULT]\",\n")
    check world.out.write("    \"types\": [\"serial\", \"integer\", \"bigint\", \"text\", \"varchar\", \"decimal\", \"boolean\", \"timestamptz\", \"json\", \"uuid\"],\n")
    check world.out.write("    \"example\": \"TABLE users\\nCOLUMN id serial NOT_NULL PRIMARY_KEY\\nCOLUMN email text NOT_NULL\\nCOLUMN name text NULLABLE\\nTABLE orders\\nCOLUMN id serial NOT_NULL PRIMARY_KEY\\nCOLUMN user_id integer NOT_NULL\"\n")
    check world.out.write("  },\n")

    // Stable error codes
    check world.out.write("  \"errors\": [\n")
    check world.out.write("    {\"code\": \"FILE_NOT_FOUND\", \"retryable\": false, \"description\": \"The --from or --to file path does not exist. Fix: verify the file path and retry.\"},\n")
    check world.out.write("    {\"code\": \"INVALID_SCHEMA\", \"retryable\": false, \"description\": \"The schema file is not parseable in Forge Schema Format. Fix: check syntax and retry.\"},\n")
    check world.out.write("    {\"code\": \"SCHEMA_TOO_LARGE\", \"retryable\": false, \"description\": \"Schema file exceeds 64KB limit. Fix: split into smaller schema files.\"},\n")
    check world.out.write("    {\"code\": \"IO_ERROR\", \"retryable\": true, \"description\": \"File system error. Retry after verifying file permissions.\"},\n")
    check world.out.write("    {\"code\": \"UNKNOWN_COMMAND\", \"retryable\": false, \"description\": \"Unrecognized command. Use forge --describe to see valid commands.\"}\n")
    check world.out.write("  ],\n")

    // MCP integration
    check world.out.write("  \"mcp\": {\n")
    check world.out.write("    \"transport\": \"stdio\",\n")
    check world.out.write("    \"protocol\": \"mcp-2025-11-25\",\n")
    check world.out.write("    \"tools\": [\"forge_analyze\"],\n")
    check world.out.write("    \"manifest_url\": \"https://forge.run/.well-known/mcp-server\",\n")
    check world.out.write("    \"invoke\": \"forge --mcp-stdio\"\n")
    check world.out.write("  },\n")

    // Programmatic signup
    check world.out.write("  \"signup\": {\n")
    check world.out.write("    \"method\": \"POST\",\n")
    check world.out.write("    \"url\": \"https://api.forge.run/v1/api-keys\",\n")
    check world.out.write("    \"body_example\": \"{\\\"plan\\\": \\\"pay-per-call\\\", \\\"spending_limit_usd\\\": 10}\",\n")
    check world.out.write("    \"response_fields\": \"api_key (string), rate_limit (object), spending_limit_usd (number)\",\n")
    check world.out.write("    \"note\": \"No email required. No browser. One HTTP call.\"\n")
    check world.out.write("  },\n")

    // Discovery
    check world.out.write("  \"discovery\": {\n")
    check world.out.write("    \"dns_txt\": \"_mcp.forge.run TXT v=mcp1; url=https://mcp.forge.run; proto=mcp\",\n")
    check world.out.write("    \"well_known\": \"https://forge.run/.well-known/mcp-server\",\n")
    check world.out.write("    \"npm\": \"npx @forge/cli\",\n")
    check world.out.write("    \"mcp_registry\": \"com.forge.schema-migration\"\n")
    check world.out.write("  }\n")
    check world.out.write("}\n")
}
