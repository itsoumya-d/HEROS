            if tci < to_len { tci = tci + 1 }
        }

        // Set-diff: from_col not in to_col = dropped; to_col not in from_col = added.
        let mut dropped_cols: u32 = 0
        let mut added_cols: u32 = 0
        let mut added_not_null_cols: u32 = 0
        let mut set_not_null_cols: u32 = 0
        let mut drop_not_null_cols: u32 = 0
        let mut add_primary_key_cols: u32 = 0
        let mut drop_primary_key_cols: u32 = 0
        let mut add_unique_cols: u32 = 0
        let mut drop_unique_cols: u32 = 0
        let mut add_fk_cols: u32 = 0
        let mut drop_fk_cols: u32 = 0
        let mut add_default_cols: u32 = 0
        let mut drop_default_cols: u32 = 0
        let mut fcs: u32 = 0
        while fcs < from_cc {
            let mut tcs: u32 = 0
            let mut fcf: bool = false
            while tcs < to_cc {
                if from_col_h1[fcs as usize] == to_col_h1[tcs as usize] {
                    if from_col_h2[fcs as usize] == to_col_h2[tcs as usize] { fcf = true }
                }
                tcs = tcs + 1
            }
            if fcf == false { dropped_cols = dropped_cols + 1 }
            fcs = fcs + 1
        }
        let mut tcs2: u32 = 0
        while tcs2 < to_cc {
            let mut fcs2: u32 = 0
            let mut tcf: bool = false
            let mut matched_fcs: u32 = from_cc
            while fcs2 < from_cc {
                if to_col_h1[tcs2 as usize] == from_col_h1[fcs2 as usize] {
                    if to_col_h2[tcs2 as usize] == from_col_h2[fcs2 as usize] {
                        tcf = true
                        matched_fcs = fcs2
                    }
                }
                fcs2 = fcs2 + 1
            }
            if tcf == false {
                added_cols = added_cols + 1
                if to_col_nn[tcs2 as usize] == 1 { added_not_null_cols = added_not_null_cols + 1 }
            } else {
                // RT-82: detect nullability changes on preserved columns.
                // RT-88: detect PRIMARY_KEY changes on preserved columns.
                if matched_fcs < from_cc {
                    if to_col_nn[tcs2 as usize] == 1 && from_col_nn[matched_fcs as usize] == 0 {
                        set_not_null_cols = set_not_null_cols + 1
                    }
                    if to_col_nn[tcs2 as usize] == 0 && from_col_nn[matched_fcs as usize] == 1 {
                        drop_not_null_cols = drop_not_null_cols + 1
                    }
                    if to_col_pk[tcs2 as usize] == 1 && from_col_pk[matched_fcs as usize] == 0 {
                        add_primary_key_cols = add_primary_key_cols + 1
                    }
                    if to_col_pk[tcs2 as usize] == 0 && from_col_pk[matched_fcs as usize] == 1 {
                        drop_primary_key_cols = drop_primary_key_cols + 1
                    }
                    // RT-92: UNIQUE constraint changes on preserved columns.
                    if to_col_uq[tcs2 as usize] == 1 && from_col_uq[matched_fcs as usize] == 0 {
                        add_unique_cols = add_unique_cols + 1
                    }
                    if to_col_uq[tcs2 as usize] == 0 && from_col_uq[matched_fcs as usize] == 1 {
                        drop_unique_cols = drop_unique_cols + 1
                    }
                    // RT-93: FOREIGN KEY (REFERENCES) changes on preserved columns.
                    if to_col_fk[tcs2 as usize] == 1 && from_col_fk[matched_fcs as usize] == 0 {
                        add_fk_cols = add_fk_cols + 1
                    }
                    if to_col_fk[tcs2 as usize] == 0 && from_col_fk[matched_fcs as usize] == 1 {
                        drop_fk_cols = drop_fk_cols + 1
                    }
                    // RT-87/DEFAULT: DEFAULT modifier changes on preserved columns.
                    if to_col_df[tcs2 as usize] == 1 && from_col_df[matched_fcs as usize] == 0 {
                        add_default_cols = add_default_cols + 1
                    }
                    if to_col_df[tcs2 as usize] == 0 && from_col_df[matched_fcs as usize] == 1 {
                        drop_default_cols = drop_default_cols + 1
                    }
                }
            }
            tcs2 = tcs2 + 1
        }

        let has_drop = dropped_tables > 0 || dropped_cols > 0
        // Adding tables is always SAFE (CREATE TABLE has no impact on existing data).
        // Only column additions to preserved tables elevate risk tier.
        let has_add = added_cols > 0

        let mut risk_tier = "SAFE"
        let mut risk_score = "0.0"
        let mut retryable = "true"
        if has_drop {
            risk_tier = "CRITICAL"
            risk_score = "1.0"
            retryable = "false"
        } else {
            if set_not_null_cols > 0 || add_primary_key_cols > 0 || add_unique_cols > 0 || add_fk_cols > 0 {
                risk_tier = "HIGH"
                risk_score = "0.75"
                retryable = "false"
            } else {
                if added_not_null_cols > 0 {
                    risk_tier = "MEDIUM"
                    risk_score = "0.5"
                    retryable = "true"
                } else {
                    if has_add || drop_not_null_cols > 0 || drop_primary_key_cols > 0 || drop_unique_cols > 0 || drop_fk_cols > 0 || add_default_cols > 0 || drop_default_cols > 0 {
                        risk_tier = "NOTABLE"
                        risk_score = "0.25"
                        retryable = "true"
                    }
                }
            }
        }

        // RT-99: if schema was truncated, ensure risk is at least NOTABLE so agent pauses.
        if schema_truncated {
            if risk_tier == "SAFE" {
                risk_tier = "NOTABLE"
                risk_score = "0.25"
                retryable = "true"
            }
        }

        // decision_required: explicit halt signal for agents (LLM06 Excessive Agency mitigation).
        // Triggers on data loss (has_drop), set_not_null (can fail/lock), or add_primary_key/add_unique
        // (ACCESS EXCLUSIVE lock + full table scan — requires human sign-off before executing).
        // MEDIUM adds are flagged in operations but not decision-gated — no data destruction.
        // Agents MUST NOT auto-proceed when decision_required is true.
        let decision_required = has_drop || set_not_null_cols > 0 || add_primary_key_cols > 0 || add_unique_cols > 0 || add_fk_cols > 0

        check world.out.write("{\"schema_version\":1,\"_forge_version\":\"0.1.4\"")
        if has_ri {
            let ri_arg = std.args.get(ri_idx)
            if ri_arg.has {
                check world.out.write(",\"request_id\":\"")
                check world.out.write(ri_arg.value)
                check world.out.write("\"")
            }
        }
        check world.out.write(",\"risk_tier\":\"")
        check world.out.write(risk_tier)
        check world.out.write("\",\"risk_score\":")
        check world.out.write(risk_score)
        check world.out.write(",\"retryable\":")
        check world.out.write(retryable)
        check world.out.write(",\"has_data_loss\":")
        if has_drop {
            check world.out.write("true")
        } else {
            check world.out.write("false")
        }
        check world.out.write(",\"decision_required\":")
        if decision_required {
            check world.out.write("true")
        } else {
            check world.out.write("false")
        }
        check world.out.write(",\"operations\":[")

        let mut first_op = true

        if dropped_tables > 0 {
            let mut fout: u32 = 0
            while fout < ftc {
                let mut tout: u32 = 0
                let mut fout_found = false
                while tout < ttc {
                    if fth[fout as usize] == tth[tout as usize] {
                        if fth2[fout as usize] == tth2[tout as usize] { fout_found = true }
                    }
                    tout = tout + 1
                }
                if fout_found == false {
                    if first_op == false { check world.out.write(",") }
                    first_op = false
                    check world.out.write("{\"type\":\"drop_table\",\"table\":\"")
                    let fn_s = fth_s[fout as usize] as usize
                    let fn_l = fth_l[fout as usize] as usize
                    let mut fn_i: usize = 0
                    let mut fn_cb: [1]u8 = [0]
                    while fn_i < fn_l {
                        fn_cb[0] = from_sp[fn_s + fn_i]
                        if isIdChar(fn_cb[0]) {
                            check world.out.write(fn_cb)
                            fn_i = fn_i + 1
                        } else {
                            check world.out.write("__INVALID_NAME__")
                            fn_i = fn_l
                        }
                    }
                    check world.out.write("\",\"risk\":\"critical\",\"data_loss\":true,\"estimated_lock_ms\":0,\"retryable\":false,\"agent_guidance\":\"Table dropped. All data permanently deleted. Verify no foreign key references or application queries target this table.\"}")
                }
                fout = fout + 1
            }
        }

        if added_tables > 0 {
            let mut tadd: u32 = 0
            while tadd < ttc {
                let mut fadd: u32 = 0
                let mut tadd_found = false
                while fadd < ftc {
                    if tth[tadd as usize] == fth[fadd as usize] {
                        if tth2[tadd as usize] == fth2[fadd as usize] { tadd_found = true }
                    }
                    fadd = fadd + 1
                }
                if tadd_found == false {
                    if first_op == false { check world.out.write(",") }
                    first_op = false
                    check world.out.write("{\"type\":\"add_table\",\"table\":\"")
                    let tn_s = tth_s[tadd as usize] as usize
                    let tn_l = tth_l[tadd as usize] as usize
                    let mut tn_i: usize = 0
                    let mut tn_cb: [1]u8 = [0]
                    while tn_i < tn_l {
                        tn_cb[0] = to_sp[tn_s + tn_i]
                        if isIdChar(tn_cb[0]) {
                            check world.out.write(tn_cb)
                            tn_i = tn_i + 1
                        } else {
                            check world.out.write("__INVALID_NAME__")
                            tn_i = tn_l
                        }
                    }
                    check world.out.write("\",\"risk\":\"safe\",\"data_loss\":false,\"estimated_lock_ms\":0,\"retryable\":true,\"agent_guidance\":\"New table added. No impact on existing tables or application code.\"}")
                }
                tadd = tadd + 1
            }
        }

        if dropped_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_column\",\"risk\":\"critical\",\"data_loss\":true,\"estimated_lock_ms\":0,\"retryable\":false,\"agent_guidance\":\"One or more columns dropped. Data cannot be recovered without a backup restore. Verify no application code reads these columns.\"}")
        }

        if set_not_null_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"set_not_null\",\"risk\":\"high\",\"data_loss\":false,\"estimated_lock_ms\":30000,\"retryable\":false,\"agent_guidance\":\"Adding NOT NULL constraint to existing column. Will fail if any row contains a null. Requires: 1) UPDATE t SET col=<default> WHERE col IS NULL; 2) then ALTER TABLE t ALTER COLUMN col SET NOT NULL. Full table scan required — slow on large tables. decision_required: must have human approval.\"}")
        }
        if add_primary_key_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_primary_key\",\"risk\":\"high\",\"data_loss\":false,\"estimated_lock_ms\":60000,\"retryable\":false,\"agent_guidance\":\"Adding PRIMARY KEY constraint to existing column. Acquires ACCESS EXCLUSIVE lock for duration of full table scan (uniqueness + NOT NULL validation). Will fail if column contains nulls or duplicate values. Zero-downtime strategy: create UNIQUE index CONCURRENTLY first, then ADD CONSTRAINT using that index. decision_required: must have human approval.\"}")
        }
        if drop_primary_key_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_primary_key\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Removing PRIMARY KEY constraint from existing column. Acquires ACCESS EXCLUSIVE lock briefly for constraint metadata removal. No data deleted. Verify no foreign keys in other tables reference this primary key before dropping.\"}")
        }
        if add_unique_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_unique\",\"risk\":\"high\",\"data_loss\":false,\"estimated_lock_ms\":60000,\"retryable\":false,\"agent_guidance\":\"Adding UNIQUE constraint to existing column. Acquires ACCESS EXCLUSIVE lock for full-table uniqueness scan. Will fail if column contains duplicate values. Zero-downtime strategy: CREATE UNIQUE INDEX CONCURRENTLY first, then ADD CONSTRAINT using that index. decision_required: must have human approval.\"}")
        }
        if drop_unique_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_unique\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Removing UNIQUE constraint from existing column. Acquires ACCESS EXCLUSIVE lock briefly for constraint metadata removal. No data deleted. Application code that relied on uniqueness guarantees should be audited.\"}")
        }
        if add_fk_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_foreign_key\",\"risk\":\"high\",\"data_loss\":false,\"estimated_lock_ms\":30000,\"retryable\":false,\"agent_guidance\":\"Adding FOREIGN KEY constraint to existing column. Acquires ACCESS EXCLUSIVE lock on constrained table and SHARE ROW EXCLUSIVE lock on referenced table. Will fail if any column value does not exist in the referenced table. Validate referential integrity before applying. decision_required: must have human approval.\"}")
        }
        if drop_fk_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_foreign_key\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Removing FOREIGN KEY constraint from existing column. Acquires ACCESS EXCLUSIVE lock briefly for constraint metadata removal. No data deleted. Application code relying on referential integrity will no longer have database-level enforcement.\"}")
        }
        if add_default_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_default\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Adding DEFAULT value to existing column. In PostgreSQL 11+ this is a fast metadata-only operation for non-volatile defaults (no table rewrite). Existing rows are NOT backfilled — only new rows will receive the default. Verify application code handles existing null rows.\"}")
        }
        if drop_default_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_default\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Dropping DEFAULT value from existing column. Fast metadata-only operation. Existing rows retain their stored values. New rows inserted without an explicit value will receive NULL (or fail NOT NULL constraint if set).\"}")
        }
        if drop_not_null_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"drop_not_null\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":100,\"retryable\":true,\"agent_guidance\":\"Removing NOT NULL constraint from existing column. No data impact — changes constraint metadata only. Application code that previously relied on NOT NULL guarantees should be audited.\"}")
        }
        if added_not_null_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_column\",\"risk\":\"medium\",\"data_loss\":false,\"estimated_lock_ms\":5000,\"retryable\":true,\"agent_guidance\":\"NOT NULL column(s) added without DEFAULT. Existing rows will fail NOT NULL constraint on next write unless you add a DEFAULT, backfill nulls first, then add the constraint in separate steps.\"}")
        }
        let added_nullable_cols = added_cols - added_not_null_cols
        if added_nullable_cols > 0 {
            if first_op == false { check world.out.write(",") }
            first_op = false
            check world.out.write("{\"type\":\"add_column\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":0,\"retryable\":true,\"agent_guidance\":\"New nullable column(s) added. Safe for most cases — no impact on existing rows or queries.\"}")
        }
        // RT-99: emit truncation warning when analysis is incomplete.
        if schema_truncated {
            if first_op == false { check world.out.write(",") }
            check world.out.write("{\"type\":\"schema_truncated\",\"risk\":\"notable\",\"data_loss\":false,\"estimated_lock_ms\":0,\"retryable\":false,\"agent_guidance\":\"One or more tables contain more than 256 columns. Columns beyond the 256-column limit were not analyzed. This result may be incomplete — actual risk may be higher. Treat as NOTABLE minimum and review manually.\"}")
        }

        check world.out.write("]}\n")
        return
    }

    check world.out.write("{\"error\":{\"code\":\"UNKNOWN_COMMAND\",\"message\":\"Unknown command. Use forge --describe to see valid commands.\",\"retryable\":false}}\n")
}
